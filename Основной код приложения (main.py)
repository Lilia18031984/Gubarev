        )
        self.add_task_button.pack(side="left", padx=(0, 5), expand=True, fill="x")
        
        self.remove_task_button = tk.Button(
            task_buttons_frame,
            text="🗑️ Удалить задачу",
            command=self.remove_task,
            bg="#e74c3c",
            fg="white",
            font=("Segoe UI", 9, "bold"),
            relief="flat",
            cursor="hand2"
        )
        self.remove_task_button.pack(side="left", expand=True, fill="x")
        
        # Правая колонка - история
        right_frame = tk.Frame(main_frame, bg="#1a1a2e")
        right_frame.pack(side="right", fill="both", expand=True, padx=(10, 0))
        
        tk.Label(
            right_frame,
            text="📜 ИСТОРИЯ ГЕНЕРАЦИЙ",
