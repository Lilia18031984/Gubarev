        )
        self.current_task_label.pack(pady=10)
        
        # Основной фрейм для двух колонок
        main_frame = tk.Frame(self.window, bg="#1a1a2e")
        main_frame.pack(fill="both", expand=True, padx=20, pady=(0, 15))
        
        # Левая колонка - список всех задач
        left_frame = tk.Frame(main_frame, bg="#1a1a2e")
        left_frame.pack(side="left", fill="both", expand=True, padx=(0, 10))
        
        tk.Label(
            left_frame,
            text="📚 ВСЕ ЗАДАЧИ",
            font=("Segoe UI", 12, "bold"),
            bg="#1a1a2e",
            fg="#ffffff"
        ).pack(anchor="w", pady=(0, 8))
        
        # Таблица задач
        task_columns = ("type", "task")
        self.task_tree = ttk.Treeview(
            left_frame,
            columns=task_columns,
            show="headings",
            height=14
        )
        
        self.task_tree.heading("type", text="Тип")
        self.task_tree.heading("task", text="Задача")
        
        self.task_tree.column("type", width=80, anchor="center")
        self.task_tree.column("task", width=280)
        
        task_scrollbar = ttk.Scrollbar(left_frame, orient="vertical", command=self.task_tree.yview)
        self.task_tree.configure(yscrollcommand=task_scrollbar.set)
        
        self.task_tree.pack(side="left", fill="both", expand=True)
        task_scrollbar.pack(side="right", fill="y")
        
        # Кнопки управления задачами
        task_buttons_frame = tk.Frame(left_frame, bg="#1a1a2e")
        task_buttons_frame.pack(fill="x", pady=(8, 0))
        
        self.add_task_button = tk.Button(
            task_buttons_frame,
            text="➕ Добавить задачу",
