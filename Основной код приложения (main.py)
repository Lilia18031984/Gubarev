            text="🎯 ГЕНЕРАЦИЯ ЗАДАЧИ",
            font=("Segoe UI", 14, "bold"),
            bg="#16213e",
            fg="#ffffff"
        ).pack(pady=(5, 10))
        
        # Фильтр по типу
        filter_frame = tk.Frame(generate_frame, bg="#16213e")
        filter_frame.pack(pady=5)
        
        tk.Label(
            filter_frame,
            text="Фильтр по типу:",
            font=("Segoe UI", 11),
            bg="#16213e",
            fg="#cccccc"
        ).pack(side="left", padx=(0, 10))
        
        self.filter_type = ttk.Combobox(
            filter_frame,
            values=self.task_types,
            font=("Segoe UI", 11),
            state="readonly",
            width=15
        )
        self.filter_type.pack(side="left")
        self.filter_type.set("Все")
        
        # Кнопка генерации
        self.generate_button = tk.Button(
            generate_frame,
            text="🎲 СГЕНЕРИРОВАТЬ ЗАДАЧУ 🎲",
            command=self.generate_task,
            bg="#e94560",
            fg="white",
            font=("Segoe UI", 12, "bold"),
            relief="flat",
            cursor="hand2",
            pady=10
        )
        self.generate_button.pack(pady=(15, 10), padx=20, fill="x")
        
        self.generate_button.bind("<Enter>", lambda e: self.generate_button.config(bg="#ff6b6b"))
        self.generate_button.bind("<Leave>", lambda e: self.generate_button.config(bg="#e94560"))
        
        # Отображение текущей задачи
        task_display_frame = tk.Frame(generate_frame, bg="#0f3460", relief="flat")
        task_display_frame.pack(fill="x", pady=(5, 10), padx=20, ipady=15)
        
        tk.Label(
            task_display_frame,
            text="📋 ТЕКУЩАЯ ЗАДАЧА",
