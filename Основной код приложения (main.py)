        ).pack(anchor="w", pady=(0, 8))
        
        # Список истории
        history_frame = tk.Frame(right_frame, bg="#16213e", relief="groove", bd=1)
        history_frame.pack(fill="both", expand=True)
        
        self.history_listbox = tk.Listbox(
            history_frame,
            bg="#0f3460",
