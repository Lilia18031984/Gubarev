        self.history_listbox.configure(yscrollcommand=history_scrollbar.set)
        history_scrollbar.pack(side="right", fill="y", pady=5)
        
        # Кнопки истории
        history_buttons_frame = tk.Frame(right_frame, bg="#1a1a2e")
        history_buttons_frame.pack(fill="x", pady=(8, 0))
        
        self.clear_history_button = tk.Button(
            history_buttons_frame,
            text="🗑️ Очистить историю",
            command=self.clear_history,
            bg="#e74c3c",
            fg="white",
            font=("Segoe UI", 9, "bold"),
            relief="flat",
            cursor="hand2"
        )
        self.clear_history_button.pack(expand=True, fill="x")
        
        # Статистика
        stats_frame = tk.Frame(self.window, bg="#16213e", relief="groove", bd=1)
        stats_frame.pack(fill="x", padx=20, pady=(0, 15), ipady=8)
        
        self.stats_label = tk.Label(
            stats_frame,
            text="",
            font=("Segoe UI", 10),
            bg="#16213e",
            fg="#4ecdc4"
        )
        self.stats_label.pack()
        
        # Статусная строка
        self.status_label = tk.Label(
            self.window,
            text="💡 Готов к работе",
            font=("Segoe UI", 9),
            bg="#1a1a2e",
            fg="#888888",
            anchor="w"
        )
        self.status_label.pack(side="bottom", fill="x", padx=20, pady=(0, 10))
        
        # Привязка клавиш
        self.window.bind("<Return>", lambda event: self.generate_task())
        
        # Обновление статистики
        self.update_statistics()
    
    def generate_task(self):
        """Генерирует случайную задачу с учётом фильтра"""
        # Получаем выбранный тип фильтра
        filter_type = self.filter_type.get()
        
        # Фильтруем задачи
        if filter_type == "Все":
            available_tasks = self.tasks
        else:
            available_tasks = [t for t in self.tasks if t["type"] == filter_type]
        
        if not available_tasks:
            messagebox.showwarning("Предупреждение", f"Нет задач типа '{filter_type}'!\nДобавьте новые задачи или смените фильтр.")
            return
        
        # Выбираем случайную задачу
        selected_task = random.choice(available_tasks)
        
        # Отображаем задачу
        self.current_task_label.config(text=f"✨ {selected_task['text']} ✨")
        
        # Добавляем в историю
        history_entry = {
            "date": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "task": selected_task["text"],
            "type": selected_task["type"]
        }
        self.history.append(history_entry)
        
        # Ограничиваем историю 100 записями
        if len(self.history) > 100:
            self.history = self.history[-100:]
        
        self.save_data()
        self.update_history_list()
        self.update_statistics()
        
        self.status_label.config(text=f"✅ Сгенерирована задача: {selected_task['text'][:50]}...", fg="#4ecdc4")
        self.window.after(3000, lambda: self.status_label.config(text="💡 Готов к работе", fg="#888888"))
        
        # Визуальный эффект
        self.current_task_label.config(fg="#f39c12")
        self.window.after(500, lambda: self.current_task_label.config(fg="#ffffff"))
    
    def add_task_dialog(self):
        """Открывает диалог добавления новой задачи"""
        dialog = tk.Toplevel(self.window)
        dialog.title("Добавить задачу")
        dialog.geometry("400x250")
        dialog.resizable(False, False)
        dialog.configure(bg="#16213e")
        
        # Центрирование диалога
        dialog.update_idletasks()
        x = self.window.winfo_x() + (self.window.winfo_width() // 2) - 200
        y = self.window.winfo_y() + (self.window.winfo_height() // 2) - 125
        dialog.geometry(f"+{x}+{y}")
        
        tk.Label(
            dialog,
            text="➕ Новая задача",
            font=("Segoe UI", 14, "bold"),
            bg="#16213e",
            fg="#ffffff"
        ).pack(pady=(15, 10))
        
        # Поле ввода текста задачи
        tk.Label(
            dialog,
            text="Текст задачи:",
            font=("Segoe UI", 10),
            bg="#16213e",
            fg="#cccccc"
        ).pack(anchor="w", padx=30, pady=(5, 0))
        
        task_entry = tk.Entry(
            dialog,
            font=("Segoe UI", 11),
            bg="#0f3460",
            fg="#ffffff",
            relief="flat",
            width=35
        )
        task_entry.pack(padx=30, pady=(5, 10))
        task_entry.focus()
        
        # Выбор типа задачи
        tk.Label(
            dialog,
            text="Тип задачи:",
            font=("Segoe UI", 10),
            bg="#16213e",
            fg="#cccccc"
        ).pack(anchor="w", padx=30, pady=(5, 0))
        
        type_combo = ttk.Combobox(
            dialog,
            values=self.task_types[1:],
            font=("Segoe UI", 11),
            state="readonly",
            width=32
        )
        type_combo.pack(padx=30, pady=(5, 15))
        type_combo.set("Другое")
        
        # Кнопки
        button_frame = tk.Frame(dialog, bg="#16213e")
        button_frame.pack(pady=10)
        
        def save_task():
            task_text = task_entry.get().strip()
            task_type = type_combo.get()
            
            # Проверка на пустую строку
            if not task_text:
                messagebox.showwarning("Ошибка", "Введите текст задачи!")
                return
            
            # Добавляем задачу
            self.tasks.append({"text": task_text, "type": task_type})
            self.save_data()
            self.update_task_list()
            self.update_statistics()
            
            dialog.destroy()
            self.status_label.config(text=f"✅ Задача добавлена: {task_text[:30]}...", fg="#4ecdc4")
            self.window.after(3000, lambda: self.status_label.config(text="💡 Готов к работе", fg="#888888"))
        
        tk.Button(
            button_frame,
            text="Сохранить",
            command=save_task,
            bg="#e94560",
            fg="white",
            font=("Segoe UI", 10, "bold"),
            relief="flat",
            cursor="hand2",
            padx=20
        ).pack(side="left", padx=5)
        
        tk.Button(
            button_frame,
            text="Отмена",
            command=dialog.destroy,
            bg="#7f8c8d",
            fg="white",
            font=("Segoe UI", 10, "bold"),
            relief="flat",
            cursor="hand2",
            padx=20
        ).pack(side="left", padx=5)
        
        task_entry.bind("<Return>", lambda event: save_task())
    
    def remove_task(self):
        """Удаляет выбранную задачу"""
        selected = self.task_tree.selection()
        if not selected:
            messagebox.showwarning("Ошибка", "Выберите задачу для удаления!")
            return
        
        item = selected[0]
        values = self.task_tree.item(item, "values")
        task_text = values[1]
        
        if messagebox.askyesno("Подтверждение", f"Удалить задачу:\n{task_text}"):
            # Находим и удаляем задачу
            for i, task in enumerate(self.tasks):
                if task["text"] == task_text:
                    self.tasks.pop(i)
                    break
            
            self.save_data()
            self.update_task_list()
            self.update_statistics()
            self.status_label.config(text=f"🗑️ Задача удалена", fg="#ff6b6b")
            self.window.after(3000, lambda: self.status_label.config(text="💡 Готов к работе", fg="#888888"))
    
    def clear_history(self):
        """Очищает историю генераций"""
        if not self.history:
            messagebox.showinfo("Информация", "История уже пуста!")
            return
        
        if messagebox.askyesno("Подтверждение", "Очистить всю историю генераций?\nЭто действие нельзя отменить!"):
            self.history = []
            self.save_data()
            self.update_history_list()
            self.update_statistics()
            self.status_label.config(text="🗑️ История очищена", fg="#ff6b6b")
            self.window.after(3000, lambda: self.status_label.config(text="💡 Готов к работе", fg="#888888"))
    
    def update_task_list(self):
        """Обновляет список задач в таблице"""
        for item in self.task_tree.get_children():
            self.task_tree.delete(item)
        
        for task in self.tasks:
            self.task_tree.insert("", "end", values=(task["type"], task["text"]))
    
    def update_history_list(self):
        """Обновляет список истории"""
        self.history_listbox.delete(0, tk.END)
        
        # Показываем историю в обратном порядке (новые сверху)
        for entry in reversed(self.history):
            display_text = f"[{entry['date']}] [{entry['type']}] {entry['task']}"
            self.history_listbox.insert(tk.END, display_text)
    
    def update_statistics(self):
        """Обновляет статистику"""
        task_count = len(self.tasks)
        history_count = len(self.history)
        
        # Подсчёт по типам
        type_counts = {}
        for task in self.tasks:
            task_type = task["type"]
            type_counts[task_type] = type_counts.get(task_type, 0) + 1
        
        type_stats = " | ".join([f"{t}: {c}" for t, c in type_counts.items()])
        
        self.stats_label.config(text=f"📊 Задач: {task_count} | Генераций: {history_count} | {type_stats}")
    
    def on_closing(self):
        """Обработка закрытия окна"""
        if self.save_data():
            self.window.destroy()
    
    def run(self):
        """Запуск приложения"""
        self.window.mainloop()

# Запуск программы
if __name__ == "__main__":
    app = TaskGenerator()
    app.run()
