import tkinter as tk
from tkinter import ttk, messagebox
import json
import random
from datetime import datetime

class TaskGenerator:
    """Приложение для генерации случайных задач"""
    
    def __init__(self):
        # Загрузка данных из файла
        self.data = self.load_data()
        self.tasks = self.data.get("tasks", [])
        self.history = self.data.get("history", [])
        
        # Предопределённые задачи
        self.default_tasks = [
            {"text": "📖 Прочитать статью по программированию", "type": "Учёба"},
            {"text": "🏃 Сделать зарядку (15 минут)", "type": "Спорт"},
            {"text": "💼 Завершить рабочий отчёт", "type": "Работа"},
            {"text": "📚 Почитать книгу 30 минут", "type": "Учёба"},
            {"text": "🧘 Пойти на прогулку", "type": "Спорт"},
            {"text": "📧 Ответить на важные письма", "type": "Работа"},
            {"text": "🎓 Пройти онлайн-курс", "type": "Учёба"},
            {"text": "🏋️ Тренировка в зале", "type": "Спорт"},
            {"text": "📊 Составить план на неделю", "type": "Работа"},
            {"text": "💻 Написать код 1 час", "type": "Учёба"},
            {"text": "🧠 Решить 5 задач на логику", "type": "Учёба"},
            {"text": "🥗 Приготовить полезный ужин", "type": "Другое"},
            {"text": "🎨 Заняться творчеством", "type": "Другое"},
            {"text": "📝 Написать пост в соцсети", "type": "Другое"},
            {"text": "🎯 Поставить цели на месяц", "type": "Работа"}
        ]
        
        # Если задач нет, загружаем предопределённые
        if not self.tasks:
            self.tasks = self.default_tasks.copy()
            self.save_data()
        
        # Типы задач
        self.task_types = ["Все", "Учёба", "Спорт", "Работа", "Другое"]
        
        # Создание главного окна
        self.window = tk.Tk()
        self.window.title("🎲 Random Task Generator")
        self.window.geometry("900x650")
        self.window.resizable(False, False)
        self.window.configure(bg="#1a1a2e")
        
        # Центрирование окна
        self.center_window()
        
        # Создание интерфейса
        self.create_widgets()
        
        # Обновление списков
        self.update_task_list()
        self.update_history_list()
        
        # Обработка закрытия окна
        self.window.protocol("WM_DELETE_WINDOW", self.on_closing)
    
    def center_window(self):
        """Центрирует окно на экране"""
        self.window.update_idletasks()
        width = 900
        height = 650
        x = (self.window.winfo_screenwidth() // 2) - (width // 2)
        y = (self.window.winfo_screenheight() // 2) - (height // 2)
        self.window.geometry(f"{width}x{height}+{x}+{y}")
    
    def load_data(self):
        """Загружает данные из JSON-файла"""
        try:
            with open("tasks.json", "r", encoding="utf-8") as file:
                return json.load(file)
        except FileNotFoundError:
            return {"tasks": [], "history": []}
        except json.JSONDecodeError:
            messagebox.showerror("Ошибка", "Файл tasks.json повреждён")
            return {"tasks": [], "history": []}
    
    def save_data(self):
        """Сохраняет данные в JSON-файл"""
        try:
            data = {
                "tasks": self.tasks,
                "history": self.history
            }
            with open("tasks.json", "w", encoding="utf-8") as file:
                json.dump(data, file, ensure_ascii=False, indent=4)
            return True
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось сохранить: {e}")
            return False
    
    def create_widgets(self):
        """Создаёт все виджеты интерфейса"""
        
        # Заголовок
        title_frame = tk.Frame(self.window, bg="#1a1a2e")
        title_frame.pack(fill="x", pady=(20, 10), padx=20)
        
        title_label = tk.Label(
            title_frame,
            text="🎲 Random Task Generator",
            font=("Segoe UI", 20, "bold"),
            bg="#1a1a2e",
